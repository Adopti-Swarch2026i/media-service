# Variables consumidas por media-service (Node/TS).
# Fuente unica de verdad para Docker Compose.

# -- Server --
PORT=8084
HOST=0.0.0.0
NODE_ENV=production

# -- Redis (cache + lock para uploads concurrentes) --
REDIS_URL=redis://redis:6379

# -- RabbitMQ (publicador de pet.image.uploaded) --
RABBITMQ_URL=amqps://adopti:${RABBITMQ_PASSWORD}@rabbitmq:5671/

# -- Cloudinary (storage de imagenes) --
CLOUDINARY_CLOUD_NAME=${CLOUDINARY_CLOUD_NAME}
CLOUDINARY_API_KEY=${CLOUDINARY_API_KEY}
CLOUDINARY_API_SECRET=${CLOUDINARY_API_SECRET}

# -- Firebase Admin (validacion de ID tokens) --
GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-credentials.json

# -- Limits --
MAX_FILE_SIZE_MB=5
THUMBNAIL_WIDTH=300
REDIS_CACHE_TTL_DAYS=30
